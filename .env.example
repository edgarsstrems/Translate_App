# Translation
# Preferred for the MVP. Create a Gemini API key in Google AI Studio.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
TRANSLATION_PROVIDER=google

# Speech recognition
# Use "local" for faster-whisper on this PC, or "openai" for OpenAI API transcription.
SPEECH_RECOGNITION_BACKEND=openai
OPENAI_API_KEY=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Optional fallback if you want Google Cloud Translation instead of Gemini.
# GOOGLE_APPLICATION_CREDENTIALS can be an absolute path or relative to this app folder.
GOOGLE_TRANSLATE_API_KEY=

# Text-to-speech
# Required for Google Cloud Text-to-Speech unless your environment is already authenticated.
# Put the service-account JSON at credentials\google-service-account.json when copying to another PC.
GOOGLE_APPLICATION_CREDENTIALS=credentials\google-service-account.json

# Optional tuning
WHISPER_MODEL_SIZE=small
WHISPER_BEAM_SIZE=3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
WHISPER_VAD_FILTER=false
WHISPER_HOTWORDS=
WHISPER_QUALITY_MODE=balanced
WHISPER_MIN_RMS=0.0
SAVE_DEBUG_AUDIO=false
VAD_ENABLED=true
VAD_RMS_THRESHOLD=0.004
VAD_PEAK_THRESHOLD=0.025
VAD_MIN_SPEECH_SECONDS=1.0
VAD_MIN_SPEECH_RATIO=0.06
VAD_PADDING_SECONDS=0.35
MAX_AUDIO_QUEUE_SIZE=2
MAX_TRANSLATION_QUEUE_SIZE=6
MAX_CHUNK_AGE_SECONDS=45
MAX_TTS_AGE_SECONDS=60
CHUNK_SECONDS=8
MIN_CHUNK_SECONDS=5
EARLY_FLUSH_SILENCE_SECONDS=0.6
CHUNK_OVERLAP_SECONDS=0.0
TTS_ENGLISH_VOICE=en-US-Standard-J
TTS_RUSSIAN_VOICE=ru-RU-Standard-D
